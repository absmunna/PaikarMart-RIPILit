# ─── Server ──────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production

# ─── Database ────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# Individual PG variables (alternative to DATABASE_URL)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your_password
PGDATABASE=paikarmart

# ─── CORS ────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ─── Security ────────────────────────────────────────────────────────
# Session / JWT secret (min 32 chars)
SESSION_SECRET=change_this_to_a_long_random_secret_string

# ─── Optional ────────────────────────────────────────────────────────
# LOG_LEVEL=info
# TRUST_PROXY=1        # Set to 1 if behind nginx/caddy/cloudflare
